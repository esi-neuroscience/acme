{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "task": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "question": "allow",
    "mymcp_*": "ask"
  },
  "model": "saia/glm-4.7",
  "provider": {
    "saia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "SAIA (GWDG Chat AI)",
      "options": {
        "baseURL": "https://chat-ai.academiccloud.de/v1",
        "apiKey": "{env:SAIA_API_KEY}"
      },
      "models": {
        "apertus-70b-instruct-2509": {"name": "Apertus 70B — Open-source instruct model", "limit": {"context": 128000, "output": 8192}},
        "deepseek-r1-distill-llama-70b": {"name": "DeepSeek R1 Distill 70B — Reasoning (Llama base)", "can_reason": true, "limit": {"context": 128000, "output": 16384}},
        "devstral-2-123b-instruct-2512": {"name": "Devstral 2 123B — Mistral's agentic coder", "limit": {"context": 128000, "output": 16384}},
        "gemma-4-31b-it": {"name": "Gemma 4 31B — Google latest", "limit": {"context": 131072, "output": 8192}},
        "glm-4.7": {"name": "GLM-4.7 (128k ctx) — Agentic coding, strong tool use", "can_reason": true, "limit": {"context": 128000, "output": 16384}},
        "internvl3.5-30b-a3b": {"name": "InternVL 3.5 30B — Vision-language", "attachment": true, "limit": {"context": 32768, "output": 4096}},
        "medgemma-27b-it": {"name": "MedGemma 27B — Medical domain specialist", "limit": {"context": 32768, "output": 4096}},
        "meta-llama-3.1-8b-instruct": {"name": "Llama 3.1 8B — Meta lightweight", "limit": {"context": 128000, "output": 4096}},
        "mistral-large-3-675b-instruct-2512": {"name": "Mistral Large 3 675B (128k ctx) — Largest model, strong generalist", "limit": {"context": 128000, "output": 32768}},
        "openai-gpt-oss-120b": {"name": "OpenAI GPT-OSS 120B — Large context model", "limit": {"context": 128000, "output": 8192}},
        "qwen3-30b-a3b-instruct-2507": {"name": "Qwen3 30B Instruct — General purpose", "can_reason": true, "limit": {"context": 131072, "output": 16384}},
        "qwen3.5-122b-a10b": {"name": "Qwen3.5 122B MoE (128k ctx) — Strong reasoning, fast", "can_reason": true, "limit": {"context": 128000, "output": 32768}},
        "qwen3.5-397b-a17b": {"name": "Qwen3.5 397B MoE (128k ctx) — Flagship reasoning, best quality", "can_reason": true, "limit": {"context": 128000, "output": 32768}},
        "qwen3.6-35b-a3b": {"name": "qwen3.6-35b-a3b — General", "limit": {"context": 128000, "output": 8192}},
        "qwen3-coder-30b-a3b-instruct": {"name": "Qwen3 Coder 30B — Code-specialized", "limit": {"context": 131072, "output": 16384}},
        "qwen3-omni-30b-a3b-instruct": {"name": "Qwen3 Omni 30B — Multimodal (text+audio)", "attachment": true, "limit": {"context": 32768, "output": 4096}},
        "teuken-7b-instruct-research": {"name": "Teuken 7B — German research model", "limit": {"context": 32768, "output": 4096}}
      }
    }
  }
}
